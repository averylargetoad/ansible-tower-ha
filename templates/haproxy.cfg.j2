# HAProxy Configuration for Ansible Tower HA
# Generated by Ansible

global
    log         127.0.0.1 local2
    chroot      /var/lib/haproxy
    pidfile     /var/run/haproxy.pid
    maxconn     4000
    user        haproxy
    group       haproxy
    daemon
    stats socket /var/lib/haproxy/stats

defaults
    mode                    http
    log                     global
    option                  httplog
    option                  dontlognull
    option http-server-close
    option forwardfor       except 127.0.0.0/8
    option                  redispatch
    retries                 3
    timeout http-request    10s
    timeout queue           1m
    timeout connect         10s
    timeout client          1m
    timeout server          1m
    timeout http-keep-alive 10s
    timeout check           10s
    maxconn                 3000

# Statistics page
listen stats
    bind *:{{ lb_stats_port }}
    mode http
    stats enable
    stats uri /
    stats realm HAProxy\ Statistics
    stats auth {{ lb_stats_user }}:{{ vault_lb_stats_password }}
    stats refresh 30s

# Frontend for Ansible Tower (HTTP)
frontend tower_http
    bind *:80
    mode http
    default_backend tower_backend_http
    # Redirect HTTP to HTTPS
    redirect scheme https code 301 if !{ ssl_fc }

# Frontend for Ansible Tower (HTTPS)
frontend tower_https
    bind *:443 ssl crt /etc/haproxy/certs/tower.pem
    mode http
    option httplog
    default_backend tower_backend_https

    # Security headers
    http-response set-header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    http-response set-header X-Frame-Options "SAMEORIGIN"
    http-response set-header X-Content-Type-Options "nosniff"

# Backend for Ansible Tower nodes
backend tower_backend_http
    mode http
    balance {{ lb_algorithm }}
    option httpchk GET /api/v2/ping/
    http-check expect status 200
{% for host in groups['tower_cluster'] %}
    server {{ host }} {{ hostvars[host].ansible_host }}:80 check inter 5s rise 2 fall 3
{% endfor %}

backend tower_backend_https
    mode http
    balance {{ lb_algorithm }}
    option httpchk GET /api/v2/ping/
    http-check expect status 200
    option ssl-hello-chk
{% for host in groups['tower_cluster'] %}
    server {{ host }} {{ hostvars[host].ansible_host }}:443 check inter 5s rise 2 fall 3 ssl verify none
{% endfor %}
