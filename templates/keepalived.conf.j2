# Keepalived Configuration for HAProxy HA
# Generated by Ansible

global_defs {
    router_id {{ ansible_hostname }}
    enable_script_security
    script_user root
}

# Script to check HAProxy health
vrrp_script check_haproxy {
    script "/usr/bin/killall -0 haproxy"
    interval 2
    weight 2
}

# VRRP instance for load balancer failover
vrrp_instance VI_1 {
    state {% if inventory_hostname == groups['load_balancers'][0] %}MASTER{% else %}BACKUP{% endif %}

    interface eth0  # Adjust to your network interface
    virtual_router_id 51
    priority {% if inventory_hostname == groups['load_balancers'][0] %}{{ keepalived_priority_node1 }}{% else %}{{ keepalived_priority_node2 }}{% endif %}

    advert_int 1

    authentication {
        auth_type PASS
        auth_pass {{ vault_keepalived_password | default('changeme') }}
    }

    virtual_ipaddress {
        {{ keepalived_vip }}/24
    }

    track_script {
        check_haproxy
    }

    # Notify scripts for state changes
    notify_master "/usr/local/bin/keepalived_notify.sh MASTER"
    notify_backup "/usr/local/bin/keepalived_notify.sh BACKUP"
    notify_fault  "/usr/local/bin/keepalived_notify.sh FAULT"
}
