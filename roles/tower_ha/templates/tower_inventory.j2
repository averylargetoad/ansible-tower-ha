# Ansible Tower Installation Inventory
# Generated by Ansible

[tower]
{% for host in groups['tower_cluster'] %}
{{ hostvars[host].ansible_host }}
{% endfor %}

[database]

[all:vars]
admin_password='{{ tower_admin_password }}'

pg_host='{{ db_host }}'
pg_port='{{ db_port }}'

pg_database='{{ db_name }}'
pg_username='{{ db_user }}'
pg_password='{{ vault_tower_pg_password }}'

# RabbitMQ Configuration
rabbitmq_username='{{ rabbitmq_user }}'
rabbitmq_password='{{ vault_rabbitmq_password }}'
rabbitmq_cookie=rabbitmqcookie

# Disable bundled database and use external PostgreSQL
pg_sslmode='prefer'

# Redis configuration (for caching)
redis_password=''
