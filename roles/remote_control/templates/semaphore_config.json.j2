{
  "mysql": {
    "host": "127.0.0.1:3306",
    "user": "semaphore",
    "pass": "{{ vault_semaphore_db_password | default('changeme') }}",
    "name": "semaphore"
  },
  "port": "3000",
  "interface": "0.0.0.0",
  "tmp_path": "/var/lib/semaphore/tmp",
  "cookie_hash": "{{ vault_semaphore_cookie_hash | default('changeme-cookie-hash-32-characters-long') }}",
  "cookie_encryption": "{{ vault_semaphore_cookie_encryption | default('changeme-encryption-key-string') }}",
  "access_key_encryption": "{{ vault_semaphore_access_key | default('changeme-access-key-encryption') }}",
  "email_sender": "semaphore@example.com",
  "email_host": "smtp.example.com",
  "email_port": "587",
  "web_host": "http://{{ ansible_host }}:3000",
  "ldap_enable": false,
  "ldap_needtls": false,
  "telegram_chat": "",
  "telegram_token": "",
  "max_parallel_tasks": 10,
  "ssh_config_path": "/var/lib/semaphore/.ssh/config"
}
