# Prometheus Configuration
# Generated by Ansible

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: 'ansible-tower-ha'
    environment: 'production'

# Alertmanager configuration
alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - localhost:9093

# Load alerting rules
rule_files:
  - '/etc/prometheus/alert_rules.yml'

# Scrape configurations
scrape_configs:
  # Prometheus itself
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Ansible Tower nodes
  - job_name: 'tower-nodes'
    static_configs:
      - targets:
{% for host in groups['tower_cluster'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}
        labels:
          cluster: 'tower'

  # PostgreSQL database cluster
  - job_name: 'postgresql'
    static_configs:
      - targets:
{% for host in groups['database_cluster'] %}
          - '{{ hostvars[host].ansible_host }}:9187'
{% endfor %}
        labels:
          cluster: 'database'

  # PostgreSQL node exporters
  - job_name: 'database-nodes'
    static_configs:
      - targets:
{% for host in groups['database_cluster'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}
        labels:
          cluster: 'database'

  # Load Balancers
  - job_name: 'haproxy'
    static_configs:
      - targets:
{% for host in groups['load_balancers'] %}
          - '{{ hostvars[host].ansible_host }}:9101'
{% endfor %}
        labels:
          cluster: 'loadbalancer'

  # Load Balancer node exporters
  - job_name: 'loadbalancer-nodes'
    static_configs:
      - targets:
{% for host in groups['load_balancers'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}
        labels:
          cluster: 'loadbalancer'

  # Collection Development Server
  - job_name: 'collection-dev'
    static_configs:
      - targets:
{% for host in groups['collection_dev'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}
        labels:
          cluster: 'development'

  # Remote Control Server
  - job_name: 'remote-control'
    static_configs:
      - targets:
{% for host in groups['remote_control'] %}
          - '{{ hostvars[host].ansible_host }}:9100'
{% endfor %}
        labels:
          cluster: 'control'

  # Tower API metrics (if available)
  - job_name: 'tower-api'
    metrics_path: '/api/v2/metrics/'
    scheme: https
    tls_config:
      insecure_skip_verify: true
    basic_auth:
      username: '{{ tower_admin_user }}'
      password: '{{ tower_admin_password }}'
    static_configs:
      - targets:
{% for host in groups['tower_cluster'] %}
          - '{{ hostvars[host].ansible_host }}'
{% endfor %}
