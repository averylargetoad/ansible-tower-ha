# Grafana Configuration
# Generated by Ansible

[server]
protocol = http
http_addr = 0.0.0.0
http_port = 3000
domain = {{ ansible_host }}
root_url = %(protocol)s://%(domain)s:%(http_port)s/

[database]
type = sqlite3
path = /var/lib/grafana/grafana.db

[security]
admin_user = admin
admin_password = {{ grafana_admin_password }}
secret_key = {{ vault_grafana_secret_key | default('changeme_secret_key') }}

[users]
allow_sign_up = false
allow_org_create = false
auto_assign_org = true
auto_assign_org_role = Viewer

[auth.anonymous]
enabled = false

[dashboards]
default_home_dashboard_path = /var/lib/grafana/dashboards/tower_dashboard.json

[alerting]
enabled = true
execute_alerts = true

[smtp]
enabled = true
host = smtp.example.com:587
user = grafana@example.com
password = {{ vault_smtp_password | default('changeme') }}
from_address = grafana@example.com
from_name = Grafana Ansible Tower

[log]
mode = console file
level = info

[metrics]
enabled = true

[unified_alerting]
enabled = true
