# PostgreSQL Client Authentication Configuration
# Generated by Ansible

# TYPE  DATABASE        USER            ADDRESS                 METHOD

# Local connections
local   all             postgres                                peer
local   all             all                                     peer

# IPv4 local connections
host    all             all             127.0.0.1/32            md5
host    all             all             ::1/128                 md5

# Tower database connections from Tower nodes
{% for host in groups['tower_cluster'] %}
host    {{ db_name }}   {{ db_user }}   {{ hostvars[host].ansible_host }}/32    md5
{% endfor %}

# Replication connections
{% for host in groups['database_cluster'] %}
host    replication     replicator      {{ hostvars[host].ansible_host }}/32    md5
{% endfor %}

# Allow connections from local network (adjust as needed)
host    all             all             192.168.1.0/24          md5
